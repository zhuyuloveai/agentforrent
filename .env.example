# ── 用户工号（比赛平台注册的工号，用于 X-User-ID 请求头） ──
USER_ID=your_employee_id

# ── 租房仿真 API 地址 ──
# 本地调试：http://localhost:8080
# 比赛环境：http://7.225.29.223:8080
RENT_API_BASE=http://localhost:8080

# ── Agent 服务端口 ──
AGENT_PORT=8191

# ── 调试模式（true=本地 Qwen 模型，false=使用比赛判题器下发的模型） ──
# 本地调试时设为 true，提交评测前必须改为 false 或删除此行
DEBUG_MODE=true

# ── 本地调试模型配置（DEBUG_MODE=true 时生效，使用 DashScope OpenAI 兼容接口） ──
DEBUG_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DEBUG_API_KEY=your_dashscope_api_key_here
DEBUG_MODEL=qwen3.5-27b

# ── 关闭 Qwen thinking 模式（true=关闭，节省 token；false=开启推理链） ──
DISABLE_THINKING=true

# ── 评测模型接口版本（v1=计入评测统计需Session-ID；v2=不计统计仅调测用） ──
MODEL_API_VERSION=v1

# ── 评测模型调用超时时间（秒，默认120） ──
MODEL_TIMEOUT=120
